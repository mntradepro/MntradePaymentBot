# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Your private Telegram channel/group ID (negative number, e.g. -1001234567890)
# To get it: add @userinfobot to your group, it will show the ID
CHAT_ID=-1001234567890

# Invite link to your channel (for display purposes)
CHAT_LINK=https://t.me/+your_invite_link

# Your USDT TRC-20 wallet address
CRYPTO_WALLET=TYourUSDTTRC20WalletAddressHere

# TronGrid API key (optional but recommended to avoid rate limits)
# Get free at: https://www.trongrid.io/
TRON_API_KEY=your_trongrid_api_key_here

# SQLite database path. On Railway, set this inside your mounted volume path.
DB_PATH=/app/data/subscriptions.db

# Website purchase webhook
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=/webhook/purchase
WEBHOOK_SECRET=change_this_secret
